# Environment Variables

# API Configuration
# For development with proxy (recommended to avoid CORS)
VITE_API_BASE_URL=/api

# For production or direct API access
# VITE_API_BASE_URL=https://ai-soc.onrender.com/api/v1

# WebSocket URL
VITE_WS_URL=wss://ai-soc.onrender.com/ws

# Optional: Development overrides (without proxy)
# VITE_API_BASE_URL=http://localhost:8000/api/v1
# VITE_WS_URL=ws://localhost:8000/ws
